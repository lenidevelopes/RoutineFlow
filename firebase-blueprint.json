{
  "entities": {
    "User": {
      "title": "User",
      "description": "The settings and profile for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "level": { "type": "number", "description": "The user's level." },
        "xp": { "type": "number", "description": "The user's experience points." },
        "isBanned": { "type": "boolean", "description": "Whether the user is banned." },
        "appVersion": { "type": "string", "description": "The version of the app the user is using." },
        "darkMode": { "type": "boolean", "description": "Whether dark mode is enabled." },
        "notifications": { "type": "boolean", "description": "Whether notifications are enabled." },
        "theme": { "type": "string", "enum": ["system", "default", "dark", "light"], "description": "The selected theme." },
        "onboardingCompleted": { "type": "boolean", "description": "Whether onboarding is finished." },
        "agreedToTerms": { "type": "boolean", "description": "Whether the user agreed to terms." },
        "skills": { "type": "object", "properties": { "discipline": { "type": "number" }, "fitness": { "type": "number" }, "focus": { "type": "number" } } },
        "skipsToday": { "type": "number", "description": "Number of skips used today." },
        "lastSkipReset": { "type": "string", "format": "date-time", "description": "Last time skip count was reset." },
        "dailyXp": { "type": "number", "description": "XP earned today." },
        "lastXpReset": { "type": "string", "format": "date-time", "description": "Last time daily XP was reset." },
        "role": { "type": "string", "description": "The user's role (e.g., 'admin', 'user')." }
      },
      "required": ["userId"]
    },
    "Task": {
      "title": "Task",
      "description": "A user-defined task.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "completed": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "dueDate": { "type": "string", "format": "date-time" },
        "checklist": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "completed": { "type": "boolean" } } } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "completed", "priority", "createdAt", "updatedAt"]
    },
    "Routine": {
      "title": "Routine",
      "description": "A structured daily routine.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["morning", "school", "evening", "custom"] },
        "activeDays": { "type": "array", "items": { "type": "string" } },
        "tasks": { "type": "array", "items": { "type": "object" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "activeDays", "tasks", "isActive", "createdAt", "updatedAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit to track.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "custom"] },
        "currentStreak": { "type": "number" },
        "bestStreak": { "type": "number" },
        "lastCompleted": { "type": "string", "format": "date-time" },
        "completedToday": { "type": "boolean" },
        "logs": { "type": "array", "items": { "type": "string", "format": "date-time" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "frequency", "currentStreak", "bestStreak", "logs", "createdAt"]
    },
    "Alarm": {
      "title": "Alarm",
      "description": "An alarm set by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "time": { "type": "string" },
        "label": { "type": "string" },
        "isActive": { "type": "boolean" },
        "routineId": { "type": "string" },
        "days": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "time", "label", "isActive", "days", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A goal to track progress.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["tasks_completed", "routine_consistency", "habit_streak", "time_spent", "xp_earned", "routines_completed"] },
        "target_value": { "type": "number" },
        "current_value": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "type", "target_value", "current_value", "status", "createdAt", "updatedAt"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "features": { "type": "object" },
        "appVersion": { "type": "string" },
        "updateMessage": { "type": "string" },
        "maintenanceMode": { "type": "boolean" }
      }
    },
    "Backup": {
      "title": "Backup",
      "description": "User data backup.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "data": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Policy": {
      "title": "Policy",
      "description": "App policies (TOS, Privacy).",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles and settings." },
    "/tasks/{taskId}": { "schema": "Task", "description": "User tasks." },
    "/routines/{routineId}": { "schema": "Routine", "description": "User routines." },
    "/habits/{habitId}": { "schema": "Habit", "description": "User habits." },
    "/alarms/{alarmId}": { "schema": "Alarm", "description": "User alarms." },
    "/goals/{goalId}": { "schema": "Goal", "description": "User goals." },
    "/appConfig/{configId}": { "schema": "AppConfig", "description": "Global app configuration." },
    "/backups/{userId}": { "schema": "Backup", "description": "User data backups." },
    "/policies/{policyId}": { "schema": "Policy", "description": "Legal policies." }
  }
}
